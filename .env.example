# Environment Configuration for FeedVote

# Database Configuration
# Default: SQLite in-memory for local development (fresh DB on each start)
# For persistent development database, use: sqlite:///./feedvote.db
DATABASE_URL=sqlite:///:memory:

# For production with MySQL, set:
# DATABASE_URL=mysql+pymysql://root:root@db:3306/feedvote

# Backend Configuration
BACKEND_URL=http://localhost:8000
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Frontend Configuration
FRONTEND_PORT=8501

# Node Configuration
NODE_ENV=development
